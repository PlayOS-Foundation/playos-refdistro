#!/bin/bash
# PlayOS compositor environment — runtime GPU detection.
#
# Checks the primary DRM driver and writes WLR_RENDERER=pixman when
# running on a virtual GPU whose dmabuf / modesetting is known broken.
# Real hardware (amdgpu, radeon, i915, nouveau, panfrost, etc.) gets
# the default EGL/GLES2 renderer.
#
# Output: /run/playos/compositor.env  (empty file = default renderer)
#
# Called by playos-compositor.service ExecStartPre before the compositor.

set -e

OUTFILE="/run/playos/compositor.env"
: > "$OUTFILE"

# Resolve the primary DRM driver name from sysfs.
DRV=""
for card in /sys/class/drm/card*; do
    link=$(readlink -f "$card/device/driver" 2>/dev/null) || continue
    DRV=$(basename "$link" 2>/dev/null) || continue
    break
done

if [ -z "$DRV" ]; then
    # No DRM device yet — let wlroots figure it out.
    exit 0
fi

case "$DRV" in
    vmwgfx|virtio_gpu|qxl|bochs)
        echo "WLR_RENDERER=pixman" > "$OUTFILE"
        ;;
esac

exit 0
