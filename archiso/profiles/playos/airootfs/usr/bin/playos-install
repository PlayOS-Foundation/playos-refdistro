#!/bin/bash
# PlayOS — Install to Internal Disk
# Copies the live system to the target disk, installs bootloader, and reboots.
#
# Usage: playos-install [DISK]
#   If DISK is not provided, auto-detects the first internal disk (nvme0n1 or sda).
#
# This script is meant to be called by playos-installer.service, which stops
# the compositor first so the installer can use the console.

set -euo pipefail

# ── Helpers ──────────────────────────────────────────────────────────────────

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

say()    { echo -e "${GREEN}==>${NC} $*"; }
warn()   { echo -e "${YELLOW}WARNING:${NC} $*"; }
die()    { echo -e "${RED}ERROR:${NC} $*"; exit 1; }
ask()    { echo -en "${CYAN}$*${NC} "; }

# ── Auto-detect internal disk ────────────────────────────────────────────────

detect_disk() {
    # Prefer NVMe, then first SATA/SAS disk, excluding USB and loop devices.
    for dev in /sys/block/nvme* /sys/block/sd* /sys/block/vd* /sys/block/mmcblk*; do
        [ -e "$dev" ] || continue
        local name; name=$(basename "$dev")
        # Skip USB-attached disks
        if [ -e "$dev/removable" ] && [ "$(cat "$dev/removable")" = "1" ]; then
            continue
        fi
        # Skip tiny devices (< 4 GB)
        local size; size=$(cat "$dev/size" 2>/dev/null || echo 0)
        # size is in 512-byte sectors; 4 GB = 8388608 sectors
        if [ "$size" -lt 8388608 ]; then
            continue
        fi
        echo "$name"
        return 0
    done
    return 1
}

# ── Main ─────────────────────────────────────────────────────────────────────

clear
echo ""
echo "  ╔══════════════════════════════════════════╗"
echo "  ║       PlayOS — Install to Disk          ║"
echo "  ╚══════════════════════════════════════════╝"
echo ""

# Determine target disk
if [ $# -ge 1 ]; then
    DISK="$1"
else
    DISK=$(detect_disk) || die "No internal disk found. Specify one: $0 <disk>"
fi

TARGET="/dev/$DISK"

# Detect partition suffix: nvme0n1 → p1, sda → 1
if [[ "$DISK" == nvme* ]] || [[ "$DISK" == mmcblk* ]]; then
    PART="${TARGET}p"
else
    PART="${TARGET}"
fi

ESP="${PART}1"
ROOT="${PART}2"

say "Target disk:   ${YELLOW}$TARGET${NC}"
say "ESP partition: ${YELLOW}$ESP${NC}"
say "Root partition:${YELLOW}$ROOT${NC}"
echo ""

# ── Confirm ──────────────────────────────────────────────────────────────────

warn "This will ERASE ALL DATA on $TARGET!"
warn "There is NO undo."
echo ""
ask "Type 'YES' (uppercase) to confirm: "
read -r CONFIRM

if [ "$CONFIRM" != "YES" ]; then
    say "Aborted by user."
    # Restart compositor so the shell comes back
    systemctl start playos-compositor 2>/dev/null || true
    exit 0
fi

echo ""

# ── Partition ────────────────────────────────────────────────────────────────

say "Partitioning $TARGET (GPT: 512 MiB ESP + remaining root) ..."
wipefs -a "$TARGET" 2>/dev/null || true
sgdisk -Z "$TARGET"
sgdisk -o "$TARGET"
sgdisk -n 1:0:+512M -t 1:ef00 -c 1:"PlayOS ESP" "$TARGET"
sgdisk -n 2:0:0     -t 2:8300 -c 2:"PlayOS Root" "$TARGET"
partprobe "$TARGET" 2>/dev/null || true
sleep 1
say "Partitions created."

# ── Format ───────────────────────────────────────────────────────────────────

say "Formatting ESP (FAT32) ..."
mkfs.fat -F32 -n PLAYOS_ESP "$ESP"

say "Formatting root (ext4) ..."
mkfs.ext4 -F -L playos_root "$ROOT"

# ── Copy root filesystem ─────────────────────────────────────────────────────

say "Copying live system to root partition ..."
mount "$ROOT" /mnt

# Copy the live root, excluding virtual filesystems and temp dirs.
# The archiso live root is at / (the EROFS + tmpfs overlay).
rsync -aAX \
    --exclude=/dev \
    --exclude=/proc \
    --exclude=/sys \
    --exclude=/run \
    --exclude=/mnt \
    --exclude=/tmp \
    --exclude=/var/tmp \
    --exclude=/lost+found \
    / /mnt/

# Create essential mount points on target
mkdir -p /mnt/{dev,proc,sys,run,mnt,tmp,var/tmp}
chmod 1777 /mnt/tmp /mnt/var/tmp

say "Root filesystem copied ($(df -h /mnt | tail -1 | awk '{print $3}') used)."

# ── Install bootloader ───────────────────────────────────────────────────────

say "Installing systemd-boot ..."
mount "$ESP" /mnt/boot

# systemd-boot install
bootctl install --esp-path=/mnt/boot --boot-path=/mnt/boot

# Write loader config
cat > /mnt/boot/loader/loader.conf <<'LOADEREOF'
timeout 3
default playos.conf
console-mode auto
LOADEREOF

# Get root PARTUUID for the kernel command line
ROOT_PARTUUID=$(blkid -s PARTUUID -o value "$ROOT")

# Write loader entry
cat > /mnt/boot/loader/entries/playos.conf <<ENTRYEOF
title   PlayOS
linux   /vmlinuz-linux
initrd  /initramfs-linux.img
options root=PARTUUID=$ROOT_PARTUUID rw quiet splash
ENTRYEOF

# Copy kernel + initramfs to ESP
cp /boot/vmlinuz-linux /mnt/boot/
cp /boot/initramfs-linux.img /mnt/boot/

say "Bootloader installed."

# ── Generate fstab ───────────────────────────────────────────────────────────

say "Generating fstab ..."
genfstab -U /mnt >> /mnt/etc/fstab

# ── Cleanup & reboot ─────────────────────────────────────────────────────────

say "Unmounting ..."
umount /mnt/boot
umount /mnt

echo ""
say "${GREEN}Installation complete!${NC}"
say "System will reboot in 5 seconds..."
echo ""
say "Remove the installation media when prompted."

sleep 5
reboot
