#!/bin/sh
# PlayOS Installer — Standalone installation script.
# Called by playos-installer-gui after writing the target disk to
# /run/playos/install-target. Writes progress stages to
# /run/playos/install-status for the GUI to poll.
#
# Flow: update repos → partition → install → configure → reboot
#
# This script replaces the OpenRC init service approach. Everything runs
# as a child of the GUI process so we can communicate via the status file.

set -e

STATUS_FILE="/run/playos/install-status"
LOG_FILE="/var/log/playos-install.log"

echo "starting" > "$STATUS_FILE"

TARGET=$(cat /run/playos/install-target 2>/dev/null || true)

if [ -z "$TARGET" ]; then
    echo "failed:No install target found" > "$STATUS_FILE"
    exit 1
fi

if [ ! -b "$TARGET" ]; then
    echo "failed:$TARGET is not a block device" > "$STATUS_FILE"
    exit 1
fi

echo "=== PlayOS Install to Disk ===" | tee "$LOG_FILE"
echo "Target: $TARGET" | tee -a "$LOG_FILE"

# ── Repositories ──────────────────────────────────────────────────────────
# Ensure both PXE cache AND Alpine CDN repos are available so setup-disk
# can install everything it needs (including packages not in our cache).
mkdir -p /etc/apk
cat > /etc/apk/repositories <<'REPOS'
http://192.168.0.196/playos/apks
http://dl-cdn.alpinelinux.org/alpine/v3.24/main
http://dl-cdn.alpinelinux.org/alpine/v3.24/community
REPOS

echo "updating_repos" > "$STATUS_FILE"
echo "Updating APK index..." | tee -a "$LOG_FILE"
if ! apk update >> "$LOG_FILE" 2>&1; then
    echo "failed:Cannot reach APK repositories" > "$STATUS_FILE"
    exit 1
fi

# ── Partitioning & Install ──────────────────────────────────────────────
echo "partitioning" > "$STATUS_FILE"
echo "Running setup-disk on $TARGET..." | tee -a "$LOG_FILE"

# Background watcher: strip escape codes, extract percentage lines from
# setup-disk's terminal output, and update the status file for the GUI.
# Write setup-disk output to a temp file instead of a pipe — child processes
# spawned by setup-disk/apk can inherit the pipe's write fd and prevent EOF.
TMPLOG=$(mktemp /tmp/playos-installlog-XXXXXX)
yes | setup-disk -m sys "$TARGET" > "$TMPLOG" 2>&1

INSTALL_OK=$?

# Copy temp log to main log and parse for progress percentages
cat "$TMPLOG" >> "$LOG_FILE"

while IFS= read -r raw; do
    clean=$(printf '%s\n' "$raw" | sed 's/\x1b\[[0-9;]*[a-zA-Z]//g; s/\x1b\].*\x07//g')
    pct=$(printf '%s\n' "$clean" | sed -n 's/.*[[:space:]]\([0-9]\{1,3\}\)%[[:space:]].*/\1/p' | tail -1)
    [ -n "$pct" ] && echo "installing:$pct" > "$STATUS_FILE"
done < "$TMPLOG"
rm -f "$TMPLOG"

if [ $INSTALL_OK -ne 0 ]; then
    echo "failed:Installation failed - check $LOG_FILE" > "$STATUS_FILE"
    exit 1
fi

# ── Post-install configuration ───────────────────────────────────────────
echo "configuring" > "$STATUS_FILE"
echo "Base install complete — configuring PlayOS services..." | tee -a "$LOG_FILE"

# Find the installed root partition (sda3 / nvme0n1p3 / mmcblk0p3).
ROOT_PART=""
case "$TARGET" in
    /dev/nvme*)
        for p in ${TARGET}p3 ${TARGET}p2 ${TARGET}p1; do
            if [ -b "$p" ] && blkid "$p" 2>/dev/null | grep -q 'TYPE="ext4"'; then
                ROOT_PART="$p"
                break
            fi
        done
        ;;
    /dev/mmcblk*)
        for p in ${TARGET}p3 ${TARGET}p2 ${TARGET}p1; do
            if [ -b "$p" ] && blkid "$p" 2>/dev/null | grep -q 'TYPE="ext4"'; then
                ROOT_PART="$p"
                break
            fi
        done
        ;;
    *)
        for p in ${TARGET}3 ${TARGET}2 ${TARGET}1; do
            if [ -b "$p" ] && blkid "$p" 2>/dev/null | grep -q 'TYPE="ext4"'; then
                ROOT_PART="$p"
                break
            fi
        done
        ;;
esac

if [ -n "$ROOT_PART" ]; then
    mount "$ROOT_PART" /mnt 2>/dev/null || true
fi

if [ -d /mnt/etc/runlevels ]; then
    echo "Configuring PlayOS services on installed root..." | tee -a "$LOG_FILE"

    # ── Install WiFi packages ─────────────────────────────────────────────
    # Users need WiFi management from the Shell UI. Install NM WiFi backend
    # (wpa_supplicant for auth, nmcli for the platform-api backend).
    echo "Installing WiFi support packages..." | tee -a "$LOG_FILE"
    apk add --root /mnt networkmanager-wifi networkmanager-cli wpa_supplicant >> "$LOG_FILE" 2>&1 || true
    ln -sf /etc/init.d/wpa_supplicant /mnt/etc/runlevels/default/wpa_supplicant

    # ── Service runlevels ────────────────────────────────────────────────
    # NetworkManager, sshd, dbus, seatd → default runlevel so they start on boot.
    ln -sf /etc/init.d/networkmanager /mnt/etc/runlevels/default/networkmanager
    ln -sf /etc/init.d/sshd            /mnt/etc/runlevels/default/sshd
    ln -sf /etc/init.d/dbus            /mnt/etc/runlevels/default/dbus
    ln -sf /etc/init.d/seatd           /mnt/etc/runlevels/default/seatd

    # ── Copy PlayOS binaries ─────────────────────────────────────────────
    # setup-disk only installs packages from repos — our custom-built binaries
    # and init scripts (bundled in the PXE apkovl) must be copied manually.
    echo "Copying PlayOS binaries and services..." | tee -a "$LOG_FILE"
    mkdir -p /mnt/etc/init.d /mnt/usr/bin /mnt/usr/lib

    for f in /etc/init.d/playos-compositor; do
        [ -f "$f" ] && cp "$f" "/mnt${f}" && chmod 0755 "/mnt${f}"
    done
    for b in /usr/bin/playos-compositor /usr/bin/playos-shell /usr/bin/playos-installer-gui; do
        [ -f "$b" ] && cp "$b" "/mnt${b}" && chmod 0755 "/mnt${b}"
    done
    for lib in /usr/lib/libraylib.so.450 /usr/lib/libraylib.so /usr/lib/libglfw.so.3; do
        [ -f "$lib" ] && cp -a "$lib" "/mnt${lib}"
    done

    # Copy samples
    if [ -d /usr/share/playos ]; then
        mkdir -p /mnt/usr/share/playos
        cp -a /usr/share/playos/* /mnt/usr/share/playos/ 2>/dev/null || true
    fi

    # ── Compositor runlevel ──────────────────────────────────────────────
    ln -sf /etc/init.d/playos-compositor /mnt/etc/runlevels/default/playos-compositor

    # ── SSH keys ─────────────────────────────────────────────────────────
    if [ -f /root/.ssh/authorized_keys ]; then
        mkdir -p /mnt/root/.ssh
        cp /root/.ssh/authorized_keys /mnt/root/.ssh/authorized_keys
        chmod 700 /mnt/root/.ssh
        chmod 600 /mnt/root/.ssh/authorized_keys
        echo "SSH keys copied to installed system" | tee -a "$LOG_FILE"
    fi

    # ── EFI boot order cleanup ───────────────────────────────────────────
    if command -v efibootmgr >/dev/null 2>&1; then
        echo "Cleaning EFI boot entries..." | tee -a "$LOG_FILE"
        for entry in $(efibootmgr | grep -E 'Fedora|Ubuntu|SteamOS|Pop|Limine|Windows|Debian' | sed 's/^Boot//;s/\*.*//' 2>/dev/null); do
            efibootmgr -b "$entry" -B 2>/dev/null && echo "Removed stale EFI entry Boot$entry" | tee -a "$LOG_FILE" || true
        done
        ALPINE_ENTRY=$(efibootmgr | grep -i 'UEFI OS\|alpine\|Alpine' | head -1 | sed 's/^Boot//;s/\*.*//')
        if [ -n "$ALPINE_ENTRY" ]; then
            efibootmgr -o "$ALPINE_ENTRY" 2>/dev/null && echo "Set Alpine as first boot" | tee -a "$LOG_FILE" || true
        fi
    fi

    umount /mnt 2>/dev/null || true
    echo "PlayOS services configured for first boot" | tee -a "$LOG_FILE"
else
    echo "Could not mount installed root — runlevel config skipped" | tee -a "$LOG_FILE"
fi

echo "complete" > "$STATUS_FILE"
echo "Install complete! Waiting for GUI to trigger reboot..." | tee -a "$LOG_FILE"

# The GUI will call reboot after showing the completion screen.
# If the GUI fails to reboot within 60s, force it.
sleep 60
reboot -f || echo b > /proc/sysrq-trigger 2>/dev/null || true
