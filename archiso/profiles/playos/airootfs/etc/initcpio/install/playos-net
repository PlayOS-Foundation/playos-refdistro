#!/bin/bash
build() {
    add_runscript

    # Bundle fixed drm_exec.ko (workaround for mkfs.erofs corruption)
    add_file /etc/initcpio/fixups/drm_exec.ko /fixup/drm_exec.ko 644

    # Bundle fixed amdgpu firmware
    for fw in /etc/initcpio/fixups/firmware/amdgpu/*.bin.zst; do
        [ -f "$fw" ] || continue
        add_file "$fw" "/fixup/firmware/amdgpu/$(basename $fw)" 644
    done

    # Bundle device profiles (workaround for tomlplusplus EROFS segfault)
    for prof in /etc/initcpio/fixups/profiles/*.toml; do
        [ -f "$prof" ] || continue
        add_file "$prof" "/fixup/profiles/$(basename $prof)" 644
    done
}
help() {
    cat <<EOF
PlayOS — configure network via DHCP in early userspace.
Tries dhcpcd first, then udhcpc, then static IP fallback.
EOF
}
