[Unit]
Description=Pre-configure system settings before firstboot prompts
Before=systemd-firstboot.service
ConditionFirstBoot=yes

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/timedatectl set-timezone UTC
ExecStart=/usr/bin/localectl set-locale LANG=en_US.UTF-8
ExecStart=/usr/bin/localectl set-keymap us

[Install]
WantedBy=sysinit.target
